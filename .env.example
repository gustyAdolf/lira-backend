# Lira Backend — Variables de entorno requeridas en producción
# Copia este fichero a .env y rellena los valores reales (nunca subas .env al repositorio)

# Clave secreta para firmar JWT — usa una cadena aleatoria larga en producción
JWT_SECRET=

# Conexión a PostgreSQL
DB_URL=jdbc:postgresql://<host>:5432/liradb
DB_USERNAME=
DB_PASSWORD=
